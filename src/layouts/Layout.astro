---
import "@fontsource/poppins/400.css";
import "@fontsource/poppins/600.css";
import "@fontsource/poppins/900.css";
import "@/styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/webp" href="/mineros-favicon-v1.webp" />
    <link rel="icon" type="image/png" href="/mineros-favicon-v1.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Adam Jaroš | {title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
