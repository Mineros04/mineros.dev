---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import ProfileIcon from "@/assets/mineros-icon.webp";
import linksJson from "@/content/socialLinks/links.json";

const socialLinks = (await getCollection("socialLinks")).sort(
  (a, b) =>
    linksJson.findIndex(l => l.id === a.id) -
    linksJson.findIndex(l => l.id === b.id)
);
---

<Layout
  title="Links"
  description="Welcome to Adam Jaroš's link hub, where you can connect with me and find everything important. One link to rule them all!"
>
  <div class="bg-anim-hero grid h-full w-full place-items-center">
    <div class="z-1 flex w-full flex-col items-center gap-y-4">
      <Image
        src={ProfileIcon}
        alt="Adam Jaroš Profile Icon"
        loading="eager"
        class="h-28 w-28"
      />
      <h2 class="text-3xl font-bold text-zinc-100">Mineros04</h2>
      <nav
        class="w-9/10 max-w-96 rounded-2xl bg-zinc-200 p-8 shadow-2xl shadow-sky-500 dark:bg-zinc-700"
      >
        <ul class="flex flex-col gap-y-4">
          {
            socialLinks.map(
              link =>
                link.data.visible && (
                  <li>
                    <a
                      href={link.data.url}
                      class="btn btn-primary btn-block btn-lg shadow-gloss-3d flex items-center gap-x-2 rounded-full border-0 text-zinc-100"
                      data-umami-event="Outbound Link"
                      data-umami-event-type="Social Media"
                      data-umami-event-link={link.data.title}
                    >
                      <Icon name={link.data.icon} class="h-8 w-8" />
                      <span class="text-xl">{link.data.title}</span>
                    </a>
                  </li>
                )
            )
          }
        </ul>
      </nav>
    </div>
  </div>
  <footer
    class="absolute bottom-4 left-1/2 -translate-x-1/2 text-center text-zinc-400 md:bottom-6 lg:bottom-8"
  >
    Copyright &copy; 2026 Adam&nbsp;Jaroš
  </footer>
</Layout>
